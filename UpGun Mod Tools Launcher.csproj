<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <PlatformTarget>x64</PlatformTarget>

    <!-- Assemblage / branding -->
    <AssemblyName>UpGunModToolsLauncher</AssemblyName>
    <RootNamespace>UpGun_Mod_Tools_Launcher</RootNamespace>
    <Product>UpGun Mod Tools Launcher</Product>
    <Version>1.0.0</Version>
    <Company>ZNS - Paulem</Company>
    <Copyright>Copyright © 2026 ZNS - Paulem</Copyright>
    <NeutralLanguage>fr</NeutralLanguage>

    <!-- Multi-plateforme : publie avec -r win-x64 / linux-x64 / osx-x64 -->
    <RuntimeIdentifiers>win-x64;linux-x64;osx-x64;osx-arm64</RuntimeIdentifiers>
    <PublishSelfContained>true</PublishSelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <ApplicationIcon>Assets\ModLauncher.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Steamworks.NET">
      <HintPath>Libs\Windows-x64\Steamworks.NET.dll</HintPath>
    </Reference>
    <PackageReference Include="Avalonia" Version="11.1.3" />
    <PackageReference Include="Avalonia.Desktop" Version="11.1.3" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.1.3" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.1.3" />
    <PackageReference Include="Avalonia.Diagnostics" Version="11.1.3" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\ModLauncher.ico" />
  </ItemGroup>

  <!-- Windows-x64 : steam_api64.dll native library -->
  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'win-x64' Or '$(RuntimeIdentifier)' == ''">
    <None Include="Libs/Windows-x64/steam_api64.dll" CopyToOutputDirectory="PreserveNewest" Link="steam_api64.dll" />
  </ItemGroup>

  <!-- Linux-x64 : libsteam_api.so native library -->
  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'linux-x64'">
    <None Include="Libs/Linux-x64/libsteam_api.so" CopyToOutputDirectory="PreserveNewest" Link="libsteam_api.so" />
  </ItemGroup>
</Project>