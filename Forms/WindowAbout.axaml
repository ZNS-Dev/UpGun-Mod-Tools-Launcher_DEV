<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UpGun_Mod_Tools_Launcher.Forms.WindowAbout"
        Title="About UpGun Mod Tools Launcher"
        Width="380" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#333333">

    <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
        <TextBlock Text="UpGun Mod Tools Launcher" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
        <!-- TODO: Dynamic version -->
        <TextBlock Text="Version 1.0.0" Foreground="Gray" HorizontalAlignment="Center" />
        <TextBlock Text="Created for the UpGun Modding Community" Foreground="LightGray" HorizontalAlignment="Center" />
        
        <Button Content="Close" Width="100" HorizontalAlignment="Center" Margin="0,15,0,0"
                HorizontalContentAlignment="Center" Click="BtnClose_Click" />
    </StackPanel>
</Window>