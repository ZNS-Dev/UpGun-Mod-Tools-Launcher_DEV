<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UpGun_Mod_Tools_Launcher.Forms"
        x:Class="UpGun_Mod_Tools_Launcher.Forms.Form2"
        Title="Publish Mod"
        Width="412" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#404040">

    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
        <!-- Main Content -->
        <StackPanel Grid.Row="0" Spacing="6">
            <!-- File .pak -->
            <TextBlock Text="File .pak" Foreground="White" FontWeight="Bold" FontSize="14" />
            <Button x:Name="BtnSelectPak" Content="Drag your file .pak here, or click to browse"
                    Height="30" Click="BtnSelectPak_Click"
                    DragDrop.AllowDrop="True" />
            <TextBox x:Name="PathPak" IsReadOnly="True" Watermark="Path to .pak file..."
                     Background="#333" Foreground="White" DragDrop.AllowDrop="True" Height="22" />

            <!-- Title -->
            <TextBlock Text="Title" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,6,0,0" />
            <TextBox x:Name="TxtTitle" Watermark="My Mod Name" MaxLength="255"
                     Background="#333" Foreground="White" Height="22" />

            <!-- Description -->
            <TextBlock Text="Description" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,6,0,0" />
            <TextBox x:Name="TxtDescription" Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                     Watermark="Describe your mod..." MaxLength="30000"
                     Background="#333" Foreground="White" />

            <!-- Icon -->
            <TextBlock Text="Icon (.png 512x512 recommended)" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,6,0,0" />
            <Button x:Name="BtnSelectIcon" Content="Drag your file .png here, or click to browse"
                    Height="30" Click="BtnSelectIcon_Click"
                    DragDrop.AllowDrop="True" />
            <Grid ColumnDefinitions="32, *" Margin="0,2,0,0">
                <Border x:Name="IconPreviewBorder" Width="32" Height="32" Background="#555"
                        BorderBrush="#888" BorderThickness="1" CornerRadius="2">
                    <Image x:Name="ImageIconPreview" Width="32" Height="32" Stretch="Uniform" />
                </Border>
                <TextBox x:Name="TxtIconPath" Grid.Column="1" Margin="6,0,0,0"
                         IsReadOnly="True" Background="#333" Foreground="White"
                         Watermark="Path to icon..." DragDrop.AllowDrop="True" />
            </Grid>

            <!-- Tags -->
            <TextBlock Text="Tags" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,6,0,0" />
            <ListBox x:Name="TagsListBox" Height="120" Background="#333" Foreground="White"
                     SelectionMode="Multiple">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="local:TagItem">
                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}"
                                  Foreground="White" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- Progress Section -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Margin="0,8,0,0">
            <ProgressBar x:Name="ProgressBar" Height="12" Minimum="0" Maximum="100" Value="0"
                        Foreground="#4CAF50" Background="#333" IsIndeterminate="False" />
            <TextBlock x:Name="TxtProgressPercent" Text="0%" Foreground="White"
                       HorizontalAlignment="Right" FontSize="12" />
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button x:Name="BtnPublishMod" Content="Publish Mod" Width="100" Height="28"
                    HorizontalContentAlignment="Center" Click="BtnPublishMod_Click" />
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Height="28"
                    HorizontalContentAlignment="Center" Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>