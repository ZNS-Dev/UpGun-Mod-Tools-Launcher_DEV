<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:UpGun_Mod_Tools_Launcher.Models"
        x:Class="UpGun_Mod_Tools_Launcher.Views.MainWindow"
        x:Name="RootWindow"
        Title="UpGun Mod Tools Launcher"
        Width="920" Height="620"
        MinWidth="760" MinHeight="520"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="48"
        ExtendClientAreaChromeHints="NoChrome"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="48,*,52">

    <!-- ===================== TITLEBAR CUSTOM ===================== -->
    <Grid Grid.Row="0" Name="TitleBarArea" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Background="Transparent"
          PointerPressed="TitleBarArea_PointerPressed">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" Spacing="10" VerticalAlignment="Center" IsHitTestVisible="False">
        <Border Width="22" Height="22" CornerRadius="6" Background="{StaticResource AccentGradientBrush}"/>
        <TextBlock Text="UpGun Mod Tools" FontWeight="SemiBold" FontSize="13.5" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Discord -->
      <Button Grid.Column="2" Classes="icon" Margin="0,0,8,0" Name="BtnDiscordMenu" Click="BtnDiscordMenu_Click">
        <TextBlock Text="Discord" FontSize="12"/>
        <Button.Flyout>
          <Flyout Placement="BottomEdgeAlignedRight">
            <StackPanel Width="190" Spacing="4">
              <Button Classes="menuitem" Content="UpGun" Click="BtnDiscordUG_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
              <Button Classes="menuitem" Content="UpGun Modding" Click="BtnDiscordUGModding_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
            </StackPanel>
          </Flyout>
        </Button.Flyout>
      </Button>

      <Button Grid.Column="3" Classes="icon" Margin="0,0,8,0" Click="BtnMinimize_Click">
        <TextBlock Text="&#x2212;" FontSize="12" FontWeight="SemiBold"/>
      </Button>
      <Button Grid.Column="4" Classes="icon" Margin="0,0,12,0" Click="BtnClose_Click">
        <TextBlock Text="&#x2715;" FontSize="11" FontWeight="SemiBold"/>
      </Button>
    </Grid>

    <!-- ===================== CONTENU ===================== -->
    <Grid Grid.Row="1" Margin="24,4,24,16" ColumnDefinitions="*,220" RowDefinitions="Auto,*">

      <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
        <TextBlock Text="Tes mods Workshop" Classes="h1"/>
        <TextBlock Text="Gère et publie tes mods pour UpGun directement depuis le launcher." Classes="subtitle" Margin="0,4,0,0"/>
      </StackPanel>

      <!-- Liste des mods -->
      <Border Grid.Row="1" Grid.Column="0" Classes="card" Padding="10" Margin="0,0,16,0">
        <Grid RowDefinitions="*,Auto">
          <ListBox Grid.Row="0" Name="ListBoxWorkshopItem"
                   SelectionChanged="ListBoxWorkshopItem_SelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="models:WorkshopItem">
                <Border Classes="card" Padding="14,12" Background="{StaticResource BgElevatedBrush}">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <Border Grid.Column="0" Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="7" Padding="9,4" VerticalAlignment="Center" Margin="0,0,12,0">
                      <TextBlock Text="{Binding PrimaryTag}" FontSize="11" FontWeight="Medium"
                                 Foreground="{StaticResource AccentBrush}"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                      <TextBlock Text="{Binding DisplayTitle}" FontWeight="SemiBold" FontSize="14"
                                  TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Tags}" Classes="muted" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="{Binding FormattedSize}" Classes="muted"
                               VerticalAlignment="Center" Margin="12,0" />

                    <TextBlock Grid.Column="3" Text="&#x203A;" FontSize="18"
                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <!-- Etat vide -->
          <StackPanel Grid.Row="0" Name="EmptyState" IsVisible="False"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
            <TextBlock Text="Aucun mod publié pour l'instant" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13.5"/>
            <TextBlock Text="Clique sur « Upload » pour publier ton premier mod." Classes="muted"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Colonne d'actions -->
      <StackPanel Grid.Row="1" Grid.Column="1" Spacing="10">
        <Button Name="BtnUpload" Classes="primary" HorizontalAlignment="Stretch" Content="Upload" Click="BtnUpload_Click"/>
        <Button Name="BtnRefreshList" Classes="secondary" HorizontalAlignment="Stretch" Content="Refresh List" Click="BtnRefreshList_Click"/>

        <Border Classes="card" Padding="14" Margin="0,10,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="App ID cible" Classes="label" Margin="0"/>
            <TextBlock Name="TxtAppId" Text="311210" FontWeight="Medium" FontSize="13"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>

    <!-- ===================== FOOTER ===================== -->
    <Border Grid.Row="2" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
          <TextBlock Name="TxtBoxVersion" Text="v1.0.0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>

        <TextBlock Grid.Column="1" Name="TxtBoxMessage" Text="" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Classes="muted" TextWrapping="Wrap"/>

        <Border Grid.Column="2" Name="BorderLastVersion" Background="Transparent" CornerRadius="6" Padding="8,3" VerticalAlignment="Center" IsVisible="False">
          <TextBlock Name="TxtBoxLastVersion" Text="" FontSize="11" Foreground="{StaticResource WarningBrush}"/>
        </Border>
      </Grid>
    </Border>

  </Grid>
</Window>
